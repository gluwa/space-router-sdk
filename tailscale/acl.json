{
  "tagOwners": {
    "tag:spacerouter-gateway": ["autogroup:admin"],
    "tag:spacerouter-node":    ["autogroup:admin"],
    "tag:spacerouter-api":     ["autogroup:admin"]
  },
  "acls": [
    {
      "action": "accept",
      "src":    ["tag:spacerouter-gateway"],
      "dst":    ["tag:spacerouter-node:9090"],
      "comment": "Proxy Gateway can reach Home Nodes on their proxy port"
    },
    {
      "action": "accept",
      "src":    ["tag:spacerouter-gateway"],
      "dst":    ["tag:spacerouter-api:8000"],
      "comment": "Proxy Gateway can reach Coordination API"
    },
    {
      "action": "accept",
      "src":    ["tag:spacerouter-node"],
      "dst":    ["tag:spacerouter-api:8000"],
      "comment": "Home Nodes can reach Coordination API for registration"
    }
  ]
}
